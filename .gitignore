# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
# iCloud-synced Desktops: .next may be a symlink to .next.nosync so the sync
# daemon can't delete dev artifacts out from under the dev server.
/.next
/.next.nosync/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma — generated client + local sqlite db
/src/generated
/prisma/dev.db
/prisma/dev.db-journal
*.db
*.db-shm
*.db-wal

# local uploaded files (mirrors the Railway volume)
/data

# tesseract.js OCR language data (downloaded at runtime, ~5MB+)
*.traineddata
# EPUB parser resource-extraction dir (legacy default before explicit temp dir)
/images

# Claude Code local harness artifacts
/.claude

# .env.example is a committed template (no secrets); the broad .env* ignore
# above would otherwise exclude it.
!.env.example
